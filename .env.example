# Context Bridge — Environment Configuration
# Copy this file to .env and fill in your values

# ─── App Settings ─────────────────────────────────────────
APP_NAME=context-bridge
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ─── Storage Backend ─────────────────────────────────────
# Options: "memory" (dev/testing) or "cosmosdb" (production)
STORAGE_BACKEND=memory

# ─── Azure Cosmos DB (only needed if STORAGE_BACKEND=cosmosdb) ─
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-key-here
COSMOS_DATABASE=context-bridge

# ─── Auth / Tokens ───────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
TOKEN_EXPIRY_SECONDS=3600

# ─── CORS (browser extension needs this) ─────────────────
CORS_ORIGINS=["http://localhost:3000","chrome-extension://*"]
